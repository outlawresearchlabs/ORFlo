{
  "env": {
    "OUTLAW_FLOW_AUTO_COMMIT": "false",
    "OUTLAW_FLOW_AUTO_PUSH": "false",
    "OUTLAW_FLOW_HOOKS_ENABLED": "true",
    "OUTLAW_FLOW_TELEMETRY_ENABLED": "true",
    "OUTLAW_FLOW_REMOTE_EXECUTION": "true",
    "OUTLAW_FLOW_GITHUB_INTEGRATION": "true"
  },
  "permissions": {
    "allow": [
      "mcp__safe-bash__safe_bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(eval *)",
      "Bash(node /tmp/*)",
      "Bash(node /var/tmp/*)",
      "Bash(node /dev/shm/*)",
      "Bash(npx /tmp/*)",
      "Bash(npx /var/tmp/*)",
      "Bash(npx /dev/shm/*)",
      "Bash(bun /tmp/*)",
      "Bash(bun /var/tmp/*)",
      "Bash(bun /dev/shm/*)"
    ]
  },
  "hooks": {
    "preEditHook": {
      "command": "node",
      "args": ["./src/cli/simple-cli.js", "hooks", "pre-edit", "--file", "${file}", "--auto-assign-agents", "true", "--load-context", "true"],
      "alwaysRun": false,
      "outputFormat": "json"
    },
    "postEditHook": {
      "command": "node",
      "args": ["./src/cli/simple-cli.js", "hooks", "post-edit", "--file", "${file}", "--format", "true", "--update-memory", "true", "--train-neural", "true"],
      "alwaysRun": true,
      "outputFormat": "json"
    },
    "preCommandHook": {
      "command": "node",
      "args": ["./src/cli/simple-cli.js", "hooks", "pre-command", "--command", "${command}", "--validate-safety", "true", "--prepare-resources", "true"],
      "alwaysRun": false,
      "outputFormat": "json"
    },
    "postCommandHook": {
      "command": "node",
      "args": ["./src/cli/simple-cli.js", "hooks", "post-command", "--command", "${command}", "--track-metrics", "true", "--store-results", "true"],
      "alwaysRun": false,
      "outputFormat": "json"
    },
    "sessionEndHook": {
      "command": "node",
      "args": ["./src/cli/simple-cli.js", "hooks", "session-end", "--generate-summary", "true", "--persist-state", "true", "--export-metrics", "true"],
      "alwaysRun": true,
      "outputFormat": "json"
    }
  },
  "mcpServers": {
    "outlaw-flow": {
      "command": "node",
      "args": [
        "./src/cli/simple-cli.js",
        "mcp",
        "start"
      ],
      "env": {
        "OUTLAW_FLOW_HOOKS_ENABLED": "true",
        "OUTLAW_FLOW_TELEMETRY_ENABLED": "true",
        "OUTLAW_FLOW_REMOTE_READY": "true",
        "OUTLAW_FLOW_GITHUB_INTEGRATION": "true"
      }
    },
    "safe-bash": {
      "command": "node",
      "args": [
        "./src/cli/simple-cli.js",
        "safe-bash",
        "start"
      ],
      "env": {
        "OUTLAW_FLOW_SAFE_BASH_LOG_LEVEL": "info"
      }
    }
  },
  "includeCoAuthoredBy": true,
  "features": {
    "autoTopologySelection": true,
    "parallelExecution": true,
    "neuralTraining": true,
    "bottleneckAnalysis": true,
    "smartAutoSpawning": true,
    "selfHealingWorkflows": true,
    "crossSessionMemory": true,
    "githubIntegration": true
  },
  "performance": {
    "maxAgents": 10,
    "defaultTopology": "hierarchical",
    "executionStrategy": "parallel",
    "tokenOptimization": true,
    "cacheEnabled": true,
    "telemetryLevel": "detailed"
  }
}